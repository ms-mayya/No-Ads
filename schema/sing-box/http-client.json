{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./http-client-options.schema.json",
  "title": "HTTPClientOptions",
  "$ref": "#/$defs/HTTPClientOptions",
  "$defs": {
    "HTTPClientOptions": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "description": "Reference existing HTTP client by tag."
        },
        {
          "$ref": "#/$defs/HTTPClientOptionsObject"
        }
      ]
    },

    "HTTPClient": {
      "allOf": [
        { "$ref": "#/$defs/HTTPClientOptionsObject" }
      ],
      "description": "Top-level HTTPClient object. Same shape as object form, but tag may be used."
    },

    "HTTPClientOptionsObject": {
      "type": "object",
      "properties": {
        "tag": {
          "type": "string"
        },
        "engine": {
          "type": "string"
        },
        "version": {
          "type": "integer",
          "enum": [1, 2, 3]
        },
        "disable_version_fallback": {
          "type": "boolean"
        },
        "headers": {
          "$ref": "#/$defs/HTTPHeader"
        },
        "tls": {
          "$ref": "#/$defs/OutboundTLSOptions"
        }
      },
      "allOf": [
        { "$ref": "#/$defs/DialerOptions" },
        {
          "if": {
            "properties": {
              "version": { "enum": [1] }
            },
            "required": ["version"]
          },
          "then": {
            "description": "HTTP/1 only."
          }
        },
        {
          "if": {
            "properties": {
              "version": { "enum": [2] }
            },
            "required": ["version"]
          },
          "then": {
            "$ref": "#/$defs/HTTP2Options"
          }
        },
        {
          "if": {
            "properties": {
              "version": { "enum": [3] }
            },
            "required": ["version"]
          },
          "then": {
            "$ref": "#/$defs/QUICOptions"
          }
        },
        {
          "if": {
            "not": {
              "required": ["version"]
            }
          },
          "then": {
            "$ref": "#/$defs/HTTP2Options",
            "description": "Version omitted behaves like 2 at runtime."
          }
        }
      ],
      "unevaluatedProperties": true
    },

    "HTTP2Options": {
      "type": "object",
      "properties": {
        "idle_timeout": {
          "$ref": "#/$defs/Duration"
        },
        "keep_alive_period": {
          "$ref": "#/$defs/Duration"
        },
        "stream_receive_window": {
          "$ref": "#/$defs/MemoryBytes"
        },
        "connection_receive_window": {
          "$ref": "#/$defs/MemoryBytes"
        },
        "max_concurrent_streams": {
          "type": "integer"
        }
      }
    },

    "QUICOptions": {
      "allOf": [
        { "$ref": "#/$defs/HTTP2Options" },
        {
          "type": "object",
          "properties": {
            "initial_packet_size": {
              "type": "integer"
            },
            "disable_path_mtu_discovery": {
              "type": "boolean"
            }
          }
        }
      ],
      "unevaluatedProperties": true
    },

    "HTTPHeader": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "array",
                "items": { "type": "string" }
              }
            ]
          }
        },
        {
          "type": "null"
        }
      ]
    },

    "OutboundTLSOptions": {
      "description": "Reuse same OutboundTLSOptions definition from service schema.",
      "type": "object"
    },

    "DialerOptions": {
      "description": "Reuse same DialerOptions definition from service schema.",
      "type": "object"
    },

    "Duration": {
      "oneOf": [
        { "type": "string" },
        { "type": "integer", "minimum": 0 }
      ]
    },

    "MemoryBytes": {
      "description": "Placeholder for byteformats.MemoryBytes.",
      "oneOf": [
        { "type": "integer", "minimum": 0 },
        { "type": "string" }
      ]
    }
  }
}
